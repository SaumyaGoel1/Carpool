#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# If running the rails server then create or migrate existing database
has_rails=false
has_server=false

for arg in "$@"; do
  if [ "$arg" = "server" ]; then
    has_server=true
  fi

  # Match common argv forms:
  # - ./bin/rails server ... (Dockerfile CMD)
  # - rails server ... (bundle exec rails server ...)
  if [ "$arg" = "./bin/rails" ] || [ "$arg" = "bin/rails" ] || [ "$arg" = "rails" ]; then
    has_rails=true
  fi
done

if [ "$has_rails" = "true" ] && [ "$has_server" = "true" ]; then
  # Avoid "server.pid already exists" issues on restart and ensure schema is ready.
  rm -f tmp/pids/server.pid
  ./bin/rails db:prepare
fi

exec "$@"
